{
  "name": "endless-runner",
  "version": "1.0.0-alpha",
  "description": "Endless Runner",
  "author": "Mark <mark@remarkablemark.org>",
  "scripts": {
    "build": "npm run clean && vite build",
    "bundle": "bash scripts/bundle.sh",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "lint:tsc": "tsc --project tsconfig.app.json",
    "prepare": "husky",
    "preview": "vite preview",
    "start": "vite --open"
  },
  "homepage": "https://remarkablegames.org/endless-runner/",
  "dependencies": {
    "@babylonjs/core": "9.12.0",
    "@tailwindcss/postcss": "4.3.1",
    "jsx-dom": "8.1.6",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "eslint": "10.3.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vite-plugin-html": "3.2.2"
  },
  "private": true,
  "license": "MIT"
}
